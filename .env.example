# GEMINI_API_KEY: Required for Gemini AI API calls (server only).
# This should be set in Vercel environment variables, not exposed to client.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Supabase credentials
# VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are exposed to the client.
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
# SUPABASE_SERVICE_ROLE_KEY is for server-only operations (if needed in API routes)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="YOUR_APP_URL"
